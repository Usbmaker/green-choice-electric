---
const nav = [
  { label: 'Services', href: '/services' },
  { label: 'Gallery',  href: '/gallery' },
  { label: 'Reviews',  href: '/reviews' },
  { label: 'About',    href: '/about' },
];
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-[72px]">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="w-10 h-10 flex items-center justify-center rounded-xl shrink-0"
          style="background: linear-gradient(340deg, hsl(145,80%,40%) 0%, hsl(175,85%,38%) 100%);">
          <iconify-icon icon="mdi:lightning-bolt" width="22" style="color:white;"></iconify-icon>
        </div>
        <span class="font-extrabold text-[1.5rem] leading-none tracking-tight header-logo-text">
          <span style="color:#16b84a">Green</span> Choice <span style="color:#16b84a">Electric</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {nav.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-2 rounded-lg text-sm font-semibold transition-colors duration-150 header-nav-link',
              currentPath.startsWith(link.href) ? 'header-nav-active' : '',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/contact"
          class="ml-3 px-6 py-2.5 rounded-btn text-sm font-bold uppercase tracking-wide transition-all hover:opacity-90 header-cta"
          style="background-color:#0d8c32;color:#fff;"
        >
          Free Estimate
        </a>
      </nav>

      <!-- Mobile button -->
      <button id="mobile-btn" class="md:hidden p-2 rounded-lg header-nav-link transition-colors" aria-label="Menu">
        <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden bg-white border-t border-gray-100 shadow-lg">
    <div class="px-4 py-3 space-y-1">
      {nav.map(link => (
        <a href={link.href} class="block px-4 py-2.5 text-sm font-semibold text-ha-text rounded-lg hover:bg-ha-gray transition-colors">
          {link.label}
        </a>
      ))}
      <a href="/contact" class="block mt-2 px-4 py-3 text-sm font-bold uppercase text-white rounded-btn text-center"
        style="background-color:#0d8c32;">Free Estimate</a>
    </div>
  </div>
</header>

<style>
  /* On hero pages: transparent header over gradient */
  #site-header { background: transparent; }
  #site-header .header-logo-text { color: white; }
  #site-header .header-logo-text span { color: rgba(255,255,255,0.9) !important; }
  #site-header .header-nav-link { color: rgba(255,255,255,0.85); }
  #site-header .header-nav-link:hover { background: rgba(255,255,255,0.15); color: white; }
  #site-header .header-nav-active { background: rgba(255,255,255,0.2); color: white; }
  #site-header .header-cta { background-color: #fff !important; color: #0d8c32 !important; }

  /* Scrolled / solid pages: white header */
  #site-header.solid { background: white; box-shadow: 0 1px 0 rgba(0,0,0,0.08); }
  #site-header.solid .header-logo-text { color: #0c0c0c; }
  #site-header.solid .header-logo-text span { color: #16b84a !important; }
  #site-header.solid .header-nav-link { color: #4f606e; }
  #site-header.solid .header-nav-link:hover { background: #f0f0f3; color: #0c0c0c; }
  #site-header.solid .header-nav-active { background: #f0f0f3; color: #0c0c0c; }
  #site-header.solid .header-cta { background-color: #0d8c32 !important; color: white !important; }
</style>

<script>
  const header = document.getElementById('site-header');
  const btn = document.getElementById('mobile-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  const hasHero = !!document.querySelector('[data-hero]');
  if (!hasHero) header?.classList.add('solid');

  window.addEventListener('scroll', () => {
    if (!hasHero) return;
    header?.classList.toggle('solid', window.scrollY > 80);
  }, { passive: true });

  btn?.addEventListener('click', () => {
    const open = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', open);
    iconOpen?.classList.toggle('hidden', !open);
    iconClose?.classList.toggle('hidden', open);
  });
</script>
