---
export interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}
const {
  title,
  description = 'Green Choice Electric — Licensed electricians serving La Jolla, Del Mar, and coastal San Diego. Smart lighting, solar, battery storage, and residential electrical.',
  bodyClass = '',
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | Green Choice Electric</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300..900;1,300..900&family=Instrument+Sans:ital,wdth,wght@0,99,400..700;1,99,400..700&display=swap" rel="stylesheet" />
    <!-- Iconify for HA-style icons -->
    <script src="https://cdn.jsdelivr.net/npm/iconify-icon@2/dist/iconify-icon.min.js" is:inline></script>
  </head>
  <body class={`font-sans antialiased text-ha-text-dark bg-white ${bodyClass}`}>
    <slot />
    <script>
      // Rewrite absolute internal links to include the GitHub Pages base path
      const base = import.meta.env.BASE_URL.replace(/\/$/, '');
      if (base) {
        document.querySelectorAll('a[href^="/"]').forEach(el => {
          const href = el.getAttribute('href')!;
          if (!href.startsWith(base)) el.setAttribute('href', base + href);
        });
      }
    </script>
  </body>
</html>
