---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Premium Electrical — La Jolla & Coastal San Diego">
  <Header />

  <!-- =============================================
       HERO  (HA pattern: vivid gradient, split 3/5 + 2/5, huge headline)
       ============================================= -->
  <section
    data-hero
    class="relative overflow-hidden hero-section"
    style="
      background: #16b84a;
      background: linear-gradient(340deg, hsl(145,80%,38%) 0%, hsl(162,82%,40%) 50%, hsl(175,85%,38%) 100%);
      margin-top: -72px;
      padding-top: 72px;
      min-height: 840px;
      height: 100vh;
      max-height: 1080px;
      display: flex;
      align-items: center;
      color: white;
      border-bottom: 1px solid rgba(0,0,0,0.1);
    "
  >
    <!-- Subtle texture overlay -->
    <div class="absolute inset-0 opacity-[0.04]"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 32px 32px;"></div>

    <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="flex flex-col lg:flex-row lg:items-center lg:gap-12">

        <!-- Left: 3/5 -->
        <div class="lg:w-3/5">
          <!-- Headline — HA exact style -->
          <h1 style="
            font-size: clamp(4rem, 10vw, 8rem);
            font-weight: 800;
            line-height: 1;
            letter-spacing: -2.56px;
            font-style: normal;
            background: linear-gradient(125deg, #FFF 29.3%, #80FFD4 89.99%);
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0;
          ">
            Electrify<br />
            <span style="
              display: block;
              line-height: 1.15;
              margin-top: -0.5rem;
            ">your home.</span>
          </h1>

          <!-- Lead — HA exact: 1.5rem, 2.25rem line-height -->
          <p class="hero-lead" style="font-size:1.5rem;line-height:2.25rem;margin-bottom:24px;margin-top:24px;color:rgba(255,255,255,0.92);">
            La Jolla's premier electrical contractor — Lutron smart lighting, solar, battery storage, and residential electrical. Licensed, local, and built around clean energy.
          </p>

          <!-- Buttons — HA exact pattern -->
          <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:24px;">
            <a
              href="/contact"
              class="hero-cta"
              style="
                font-family: 'Figtree','Helvetica Neue',Arial,sans-serif;
                background-color: #0d8c32;
                color: white;
                text-transform: uppercase;
                font-size: 1.25rem;
                font-weight: 700;
                padding: 10px 20px 10px 28px;
                border-radius: 32px;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: 8px;
                transition: opacity 0.15s;
              "
            >
              Get an estimate
              <iconify-icon icon="mdi:arrow-right" width="22"></iconify-icon>
            </a>
            <div style="display:flex;flex-direction:column;gap:2px;">
              <a href="tel:+18588697440" style="color:rgba(255,255,255,0.9);font-size:1rem;font-weight:600;text-decoration:none;padding:8px 12px;border-radius:32px;transition:background 0.15s;">(858) 869-7440</a>
              <a href="/services" style="color:rgba(255,255,255,0.9);font-size:1rem;font-weight:600;text-decoration:none;padding:8px 12px;border-radius:32px;transition:background 0.15s;">Browse our services</a>
            </div>
          </div>

          <!-- Social proof — HA pattern: trust badge -->
          <div style="display:flex;align-items:center;gap:24px;flex-wrap:wrap;padding-top:16px;">
            <div style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:12px;border:1px solid rgba(255,255,255,0.3);background:rgba(255,255,255,0.12);backdrop-filter:blur(8px);">
              <iconify-icon icon="mdi:shield-check" width="24" style="color:rgba(255,255,255,0.9);"></iconify-icon>
              <p style="color:white;font-size:0.95rem;font-weight:400;line-height:1.3;margin:0;">
                <strong style="font-weight:700;">CA C-10 Licensed</strong><br />
                <span style="opacity:0.8;font-size:0.8rem;">Fully insured &amp; bonded</span>
              </p>
            </div>
            <div style="display:flex;align-items:center;gap:8px;opacity:0.85;">
              <div style="display:flex;gap:2px;">
                {Array.from({length:5}).map(() => (
                  <iconify-icon icon="mdi:star" width="18" style="color:#FFD700;"></iconify-icon>
                ))}
              </div>
              <p style="color:white;font-size:0.95rem;font-weight:600;margin:0;">5.0 on Google</p>
            </div>
          </div>
        </div>

        <!-- Right: 2/5 — Smart home control mockup (HA-style demo frame) -->
        <div class="hidden lg:block lg:w-2/5">
          <div style="
            border-radius: 28px;
            border: 10px solid rgba(255,255,255,0.3);
            box-shadow: 24px 64px 64px rgba(0, 60, 20, 0.4);
            overflow: hidden;
            background: white;
            aspect-ratio: 9/16;
            max-height: 580px;
            position: relative;
          ">
            <!-- Simulated smart home dashboard -->
            <div style="background:#f2f4f9;height:100%;padding:16px;font-family:Figtree,sans-serif;overflow:hidden;">
              <!-- Status bar -->
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;font-size:11px;color:#4f606e;">
                <span style="font-weight:700;">Green Choice</span>
                <div style="display:flex;gap:4px;align-items:center;">
                  <iconify-icon icon="mdi:wifi" width="12"></iconify-icon>
                  <iconify-icon icon="mdi:battery" width="12"></iconify-icon>
                </div>
              </div>

              <!-- Welcome card -->
              <div style="background:linear-gradient(135deg,hsl(145,80%,38%),hsl(175,85%,38%));border-radius:16px;padding:14px;margin-bottom:10px;color:white;">
                <p style="font-size:11px;opacity:0.8;margin:0 0 4px 0;">Good evening</p>
                <p style="font-size:16px;font-weight:800;margin:0;letter-spacing:-0.5px;">Your home is<br/>100% solar powered</p>
                <div style="display:flex;gap:8px;margin-top:10px;">
                  <div style="background:rgba(255,255,255,0.2);border-radius:8px;padding:6px 8px;font-size:10px;font-weight:700;">8.4 kW solar</div>
                  <div style="background:rgba(255,255,255,0.2);border-radius:8px;padding:6px 8px;font-size:10px;font-weight:700;">94% battery</div>
                </div>
              </div>

              <!-- Lutron lighting -->
              <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#4f606e;margin:0 0 6px 0;">Lighting</p>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:10px;">
                {[
                  {room:'Living Room',level:'65%',on:true},
                  {room:'Kitchen',level:'100%',on:true},
                  {room:'Master',level:'30%',on:true},
                  {room:'Office',level:'Off',on:false},
                ].map(r => (
                  <div style={`background:white;border-radius:12px;padding:10px;display:flex;flex-direction:column;gap:4px;opacity:${r.on?'1':'0.5'}`}>
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                      <iconify-icon icon="mdi:lightbulb" width="14" style={`color:${r.on?'#16b84a':'#ccc'}`}></iconify-icon>
                      <div style={`width:24px;height:14px;border-radius:7px;background:${r.on?'#16b84a':'#e0e0e0'};display:flex;align-items:center;${r.on?'justify-content:flex-end;':'justify-content:flex-start;'}padding:2px;`}>
                        <div style="width:10px;height:10px;border-radius:5px;background:white;"></div>
                      </div>
                    </div>
                    <p style="font-size:9px;font-weight:700;color:#0c0c0c;margin:0;">{r.room}</p>
                    <p style="font-size:9px;color:#8792a2;margin:0;">{r.level}</p>
                  </div>
                ))}
              </div>

              <!-- EV Charger -->
              <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#4f606e;margin:0 0 6px 0;">EV Charger</p>
              <div style="background:white;border-radius:12px;padding:10px;display:flex;align-items:center;gap:10px;">
                <div style="width:32px;height:32px;border-radius:8px;background:#e8f8ef;display:flex;align-items:center;justify-content:center;">
                  <iconify-icon icon="mdi:ev-plug-type2" width="18" style="color:#16b84a;"></iconify-icon>
                </div>
                <div style="flex:1;">
                  <p style="font-size:10px;font-weight:700;margin:0;color:#0c0c0c;">Tesla Model 3</p>
                  <div style="width:100%;height:4px;background:#e0e0e0;border-radius:2px;margin-top:4px;">
                    <div style="width:72%;height:100%;background:linear-gradient(90deg,#16b84a,#0fb8a0);border-radius:2px;"></div>
                  </div>
                  <p style="font-size:9px;color:#8792a2;margin:2px 0 0 0;">72% · est. full in 1h 20m</p>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- =============================================
       FEATURE CARDS  (HA: white bg, 3-col, icon in rounded container)
       ============================================= -->
  <section style="background:#fff;padding:64px 0 80px;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div style="text-align:center;margin-bottom:48px;">
        <p style="font-size:0.8125rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:#16b84a;margin-bottom:12px;">What We Do</p>
        <h2 class="section-h2" style="font-size:2.5rem;font-weight:800;letter-spacing:-0.5px;color:#0c0c0c;line-height:1.1;">Premium Electrical Services</h2>
        <p style="font-size:1.125rem;color:#4f606e;max-width:520px;margin:12px auto 0;line-height:1.7;">From smart home lighting to whole-home solar — everything electrical, done with precision and care.</p>
      </div>

      <!-- 3-col grid — HA exact: border-radius:24px, padding:24px, white bg -->
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;" class="feature-grid">
        {[
          {
            icon: 'mdi:lightbulb-auto',
            color: '#7c3aed',
            bg: '#ede9fe',
            title: 'Lutron Smart Lighting',
            body: 'Certified Lutron® dealer. Homeworks QSX, RadioRA 3, and Caseta — whole-home scenes, motorized shades, and full smart home integration.',
            href: '/services#lutron',
          },
          {
            icon: 'mdi:home-lightning-bolt',
            color: '#475569',
            bg: '#f1f5f9',
            title: 'Savant Smart Panel',
            body: "Add per-circuit intelligence to your existing panel — live energy monitoring, remote on/off switching, and automated load-shedding. No panel replacement required.",
            href: '/services#smart-panel',
          },
          {
            icon: 'mdi:battery-charging-high',
            color: '#0369a1',
            bg: '#dbeafe',
            title: 'Battery Storage',
            body: 'Savant Power System — solar, battery, and EV as one intelligent platform. Also Tesla Powerwall 3 and Enphase IQ installed and programmed.',
            href: '/services#battery',
          },
          {
            icon: 'mdi:lightning-bolt',
            color: '#16b84a',
            bg: '#dcfce7',
            title: 'Residential Electrical',
            body: 'Panel upgrades, EV chargers, recessed lighting, outlets, and everything in between. Fully permitted, inspected, done right.',
            href: '/services#residential',
          },
          {
            icon: 'mdi:ev-plug-type2',
            color: '#0fb8a0',
            bg: '#ccfbf1',
            title: 'EV Charger Installation',
            body: 'Level 2 ChargePoint, Tesla Wall Connector, and more on a dedicated circuit — so you wake up to a full charge every morning.',
            href: '/services#residential',
          },
          {
            icon: 'mdi:home-automation',
            color: '#dc2626',
            bg: '#fee2e2',
            title: 'Smart Home Integration',
            body: 'Lutron + solar + battery + EV as one cohesive system — controlled from a single app, optimized automatically.',
            href: '/services',
          },
        ].map(card => (
          <a href={card.href} class="feature-card" style="
            background: #fff;
            border-radius: 24px;
            padding: 24px;
            display: block;
            text-decoration: none;
            border: 1px solid #e8edf0;
            transition: box-shadow 0.2s, transform 0.2s;
            vertical-align: top;
          ">
            <!-- HA icon treatment: large icon in rounded-square container -->
            <div style={`
              font-size: 2.5rem;
              border-radius: 64px;
              background: ${card.bg};
              display: inline-flex;
              align-items: center;
              justify-content: center;
              padding: 16px;
              margin-bottom: 12px;
              color: ${card.color};
            `}>
              <iconify-icon icon={card.icon} width="40" style={`color:${card.color};`}></iconify-icon>
            </div>
            <div style={`font-family:Figtree,sans-serif;font-size:1.3125rem;line-height:1.625rem;color:${card.color};font-weight:600;padding-bottom:8px;`}>
              {card.title}
            </div>
            <p style="font-size:0.9375rem;line-height:1.6;color:#4f606e;margin:0;">{card.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- =============================================
       LUTRON FEATURE SECTION  (HA alternating: gray bg, image left + copy right)
       ============================================= -->
  <section style="background:#f0f0f3;padding:80px 0;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;" class="split-grid">
        <!-- Visual: Lutron keypad card -->
        <div>
          <div style="
            background: linear-gradient(160deg, #1e1040 0%, #2d1b6e 100%);
            border-radius: 24px;
            padding: 32px;
            box-shadow: 0 24px 48px rgba(0,0,0,0.15);
          ">
            <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:rgba(255,255,255,0.5);margin-bottom:16px;">Lutron Homeworks QSX · Living Room</p>
            <!-- Scene buttons -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:20px;">
              {['Morning','Entertain','Evening','Away'].map((s,i) => (
                <div style={`
                  border-radius: 12px;
                  padding: 12px 14px;
                  font-size: 14px;
                  font-weight: 700;
                  border: 1px solid rgba(255,255,255,0.12);
                  ${i===2
                    ? 'background:rgba(124,58,237,0.4);color:#d4b8ff;border-color:rgba(124,58,237,0.5);'
                    : 'background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.6);'}
                `}>{s}</div>
              ))}
            </div>
            <!-- Dimmer -->
            <div style="margin-bottom:14px;">
              <div style="display:flex;justify-content:space-between;font-size:12px;color:rgba(255,255,255,0.5);margin-bottom:6px;">
                <span>Brightness</span><span style="color:#d4b8ff;font-weight:700;">65%</span>
              </div>
              <div style="height:6px;background:rgba(255,255,255,0.1);border-radius:3px;overflow:hidden;">
                <div style="height:100%;width:65%;background:linear-gradient(90deg,#7c3aed,#a78bfa);border-radius:3px;"></div>
              </div>
            </div>
            <!-- Shades -->
            <div style="background:rgba(255,255,255,0.05);border-radius:12px;padding:10px 12px;display:flex;align-items:center;gap:10px;">
              <iconify-icon icon="mdi:blinds" width="18" style="color:rgba(255,255,255,0.6);"></iconify-icon>
              <div style="flex:1;">
                <p style="font-size:12px;font-weight:700;color:white;margin:0;">Motorized Shades · 40% open</p>
              </div>
              <div style="width:32px;height:18px;border-radius:9px;background:rgba(124,58,237,0.5);display:flex;align-items:center;justify-content:flex-end;padding:3px;">
                <div style="width:12px;height:12px;border-radius:6px;background:white;"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Copy -->
        <div>
          <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 12px;border-radius:32px;background:#ede9fe;color:#7c3aed;font-size:12px;font-weight:700;margin-bottom:20px;">
            <iconify-icon icon="mdi:certificate" width="14"></iconify-icon>
            Certified Lutron® Dealer
          </div>
          <h2 class="section-h2" style="font-size:2.5rem;font-weight:800;letter-spacing:-0.5px;color:#0c0c0c;line-height:1.1;margin-bottom:20px;">
            Lighting that responds to your life
          </h2>
          <p style="font-size:1.125rem;color:#4f606e;line-height:1.75;margin-bottom:28px;">
            Lutron Homeworks QSX is the gold standard for luxury whole-home lighting — and we're a certified dealer. From flagship QSX installs to wireless RadioRA 3 and retrofit Caseta systems, we design and program every zone so your home feels exactly right, every time you walk in.
          </p>
          <ul style="list-style:none;padding:0;margin:0 0 28px;display:flex;flex-direction:column;gap:10px;">
            {['Homeworks QSX & RadioRA 3 whole-home systems','Motorized shade integration & daylight control','Palladiom & Sunnata architectural keypads','Apple HomeKit, Alexa & Google Home','Caseta retrofit — no rewiring needed'].map(f => (
              <li style="display:flex;align-items:center;gap:10px;font-size:0.9375rem;color:#4f606e;">
                <iconify-icon icon="mdi:check-circle" width="18" style="color:#16b84a;flex-shrink:0;"></iconify-icon>
                {f}
              </li>
            ))}
          </ul>
          <a href="/services#lutron" style="
            display:inline-flex;align-items:center;gap:6px;
            background-color:#0d8c32;color:white;
            font-weight:700;font-size:1rem;
            padding:10px 20px;border-radius:32px;text-decoration:none;
            text-transform:uppercase;letter-spacing:0.04em;
            transition:opacity 0.15s;
          ">
            Learn more <iconify-icon icon="mdi:arrow-right" width="18"></iconify-icon>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- =============================================
       SOLAR + BATTERY SECTION (HA: white bg, copy left, visual right)
       ============================================= -->
  <section style="background:#fff;padding:80px 0;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;" class="split-grid">
        <!-- Copy -->
        <div>
          <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 12px;border-radius:32px;background:#dbeafe;color:#0369a1;font-size:12px;font-weight:700;margin-bottom:20px;">
            <iconify-icon icon="mdi:certificate" width="14"></iconify-icon>
            Savant® Certified Installer
          </div>
          <h2 class="section-h2" style="font-size:2.5rem;font-weight:800;letter-spacing:-0.5px;color:#0c0c0c;line-height:1.1;margin-bottom:20px;">
            Your home, off the grid
          </h2>
          <p style="font-size:1.125rem;color:#4f606e;line-height:1.75;margin-bottom:28px;">
            The Savant Power System is the most complete home energy solution on the market — and we're certified installers. Solar, battery storage, circuit-level load control, and EV charging all run through the Savant app. We also install Tesla Powerwall 3 and Enphase IQ for a streamlined solar+storage solution.
          </p>
          <ul style="list-style:none;padding:0;margin:0 0 28px;display:flex;flex-direction:column;gap:10px;">
            {[
              'Savant Power System — solar, battery & EV in one platform',
              'Tesla Powerwall 3 & Enphase IQ battery options',
              'Solar inverter wiring, interconnection & NEM metering',
              'Revenue-grade per-circuit monitoring and load-shedding',
              'Savant App setup, training & ongoing optimization',
            ].map(f => (
              <li style="display:flex;align-items:center;gap:10px;font-size:0.9375rem;color:#4f606e;">
                <iconify-icon icon="mdi:check-circle" width="18" style="color:#16b84a;flex-shrink:0;"></iconify-icon>
                {f}
              </li>
            ))}
          </ul>
          <a href="/services#battery" style="
            display:inline-flex;align-items:center;gap:6px;
            background-color:#0d8c32;color:white;
            font-weight:700;font-size:1rem;
            padding:10px 20px;border-radius:32px;text-decoration:none;
            text-transform:uppercase;letter-spacing:0.04em;
          ">
            Learn more <iconify-icon icon="mdi:arrow-right" width="18"></iconify-icon>
          </a>
        </div>

        <!-- Energy dashboard mockup -->
        <div>
          <div style="
            background: linear-gradient(160deg, #062030 0%, #083048 100%);
            border-radius: 24px;
            padding: 28px;
            box-shadow: 0 24px 48px rgba(0,0,0,0.12);
          ">
            <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:rgba(255,255,255,0.45);margin-bottom:16px;">Savant App · Live Energy Dashboard</p>
            <!-- Stats row -->
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:16px;">
              {[
                {label:'Solar',val:'8.4 kW',icon:'mdi:solar-power-variant',color:'#fbbf24'},
                {label:'Battery',val:'94%',icon:'mdi:battery-charging',color:'#34d399'},
                {label:'Grid',val:'0 kW',icon:'mdi:transmission-tower',color:'rgba(255,255,255,0.3)'},
              ].map(m => (
                <div style="background:rgba(255,255,255,0.06);border-radius:12px;padding:10px;text-align:center;">
                  <iconify-icon icon={m.icon} width="20" style={`color:${m.color};`}></iconify-icon>
                  <p style={`font-size:14px;font-weight:800;color:${m.color};margin:4px 0 0;`}>{m.val}</p>
                  <p style="font-size:10px;color:rgba(255,255,255,0.4);margin:2px 0 0;">{m.label}</p>
                </div>
              ))}
            </div>
            <!-- Battery bar -->
            <div style="background:rgba(255,255,255,0.05);border-radius:12px;padding:12px 14px;margin-bottom:10px;">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                <span style="font-size:12px;font-weight:700;color:white;">Savant PS20</span>
                <span style="font-size:11px;color:#34d399;font-weight:700;">Charging +1.2 kW</span>
              </div>
              <div style="height:8px;background:rgba(255,255,255,0.1);border-radius:4px;overflow:hidden;">
                <div style="height:100%;width:94%;background:linear-gradient(90deg,#0fb8a0,#34d399);border-radius:4px;"></div>
              </div>
              <p style="font-size:10px;color:rgba(255,255,255,0.35);margin:6px 0 0;">Est. full in 18 min</p>
            </div>
            <!-- Savings -->
            <div style="background:rgba(22,184,74,0.12);border:1px solid rgba(22,184,74,0.25);border-radius:12px;padding:10px 14px;display:flex;align-items:center;gap:10px;">
