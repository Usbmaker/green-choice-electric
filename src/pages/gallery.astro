---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const categories = ['All', 'Lutron', 'Solar', 'Battery', 'Residential'];

const stats = [
  { value: 200,  suffix: '+',    label: 'Permitted projects',         icon: 'mdi:home-lightning-bolt', color: '#16b84a' },
  { value: 750,  suffix: ' kW+', label: 'Solar capacity installed',   icon: 'mdi:solar-power-variant', color: '#f59e0b' },
  { value: 1200, suffix: '+',    label: 'Smart zones programmed',     icon: 'mdi:lightbulb-auto',      color: '#a78bfa' },
  { value: 100,  suffix: '%',    label: 'First-inspection pass rate', icon: 'mdi:certificate',         color: '#38bdf8' },
];

const projects = [
