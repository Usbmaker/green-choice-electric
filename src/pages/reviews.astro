---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const reviews = [
  { name: 'Michael T.', location: 'La Jolla', rating: 5, date: 'March 2025', service: 'Solar + Battery', dark: true,
    body: "Green Choice installed our 12 kW solar system with a Tesla Powerwall 3 and the whole process was seamless. Seth handled every permit, communicated every step of the way, and the install crew was incredibly clean and professional. We went live ahead of schedule." },
  { name: 'Jennifer L.', location: 'Del Mar', rating: 5, date: 'February 2025', service: 'Lutron', dark: false,
    body: "We had Lutron RadioRA 3 installed throughout our home — 38 zones including motorized shades in the living room and master. Seth spent time understanding exactly how we use each space and programmed scenes we actually use every day. It's genuinely transformed how our home feels." },
  { name: 'David K.', location: 'Bird Rock', rating: 5, date: 'January 2025', service: 'Panel + EV Charger', dark: false,
    body: "I needed a 200A panel upgrade and a Level 2 charger for a new Tesla. Seth gave me a competitive quote, explained exactly what was needed (and what wasn't), and had it done in a single day. Everything passed inspection first try." },
  { name: 'Sarah M.', location: 'Rancho Santa Fe', rating: 5, date: 'December 2024', service: 'Battery Storage', dark: true,
    body: "After losing power during a storm, we finally got serious about battery backup. Green Choice installed two Savant Power Storage PS20 units paired with our existing solar. First outage since — we didn't even notice it. The Savant app showing our home running entirely on stored solar is so satisfying." },
  { name: 'Robert A.', location: 'Carmel Valley', rating: 5, date: 'November 2024', service: 'Solar', dark: false,
    body: "I got three quotes for solar and Green Choice wasn't the cheapest — but Seth was the only one who showed me an actual load analysis and explained why our south and west faces would outperform what another contractor proposed. Eight months in, we're producing exactly what he projected." },
  { name: 'Christine W.', location: 'Solana Beach', rating: 5, date: 'October 2024', service: 'Lutron Caseta', dark: false,
    body: "We wanted smart lighting but were worried about the cost of rewiring. Seth recommended Caseta and retrofitted our entire downstairs in one day. Works perfectly with Apple HomeKit. Clean install — you'd never know anything changed." },
];

const stats = [
  { value: '5.0', label: 'Average rating', sub: 'Across Google & Yelp', icon: 'mdi:star' },
  { value: '100+', label: 'Projects completed', sub: 'In coastal San Diego', icon: 'mdi:home-lightning-bolt' },
  { value: '100%', label: 'Permit pass rate', sub: 'First inspection, every time', icon: 'mdi:certificate' },
];
---

<Layout title="Reviews" description="Read what La Jolla homeowners say about Green Choice Electric — 5-star reviews for solar, Lutron smart lighting, battery storage, and residential electrical.">
  <Header />

  <!-- Page header -->
  <div style="
    background: linear-gradient(340deg, hsl(145,80%,38%) 0%, hsl(162,82%,40%) 50%, hsl(175,85%,38%) 100%);
    padding: 120px 0 72px;
    text-align: center;
    color: white;
    border-bottom: 1px solid rgba(0,0,0,0.1);
  " class="page-header">
    <div class="max-w-3xl mx-auto px-4">
      <p style="font-size:0.8125rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:rgba(255,255,255,0.75);margin-bottom:12px;">What Customers Say</p>
      <h1 style="
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 800;
        letter-spacing: -1px;
        line-height: 1.05;
        margin-bottom: 20px;
        background: linear-gradient(125deg, #FFF 29.3%, #80FFD4 89.99%);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      ">Reviews</h1>
      <div style="display:flex;align-items:center;justify-content:center;gap:4px;">
        {Array.from({length:5}).map(() => (
          <iconify-icon icon="mdi:star" width="28" style="color:#FFD700;"></iconify-icon>
        ))}
        <span style="margin-left:8px;font-weight:800;font-size:1.25rem;color:white;">5.0</span>
        <span style="color:rgba(255,255,255,0.7);font-size:0.9375rem;margin-left:6px;">on Google</span>
      </div>
    </div>
  </div>

  <!-- Stats bar -->
  <div style="background:#fff;border-bottom:1px solid #e8edf0;">
    <div class="max-w-4xl mx-auto px-4 sm:px-6" style="padding-top:36px;padding-bottom:36px;">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;text-align:center;" class="stats-grid">
        {stats.map(s => (
          <div style="padding:0 16px;">
            <div style="display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:4px;">
              <iconify-icon icon={s.icon} width="22" style="color:#16b84a;"></iconify-icon>
              <p class="stats-val" style="font-size:2.25rem;font-weight:800;letter-spacing:-1px;color:#0c0c0c;margin:0;">{s.value}</p>
            </div>
            <p style="font-size:0.9375rem;font-weight:700;color:#0c0c0c;margin:0;">{s.label}</p>
            <p style="font-size:0.8125rem;color:#8792a2;margin:3px 0 0;">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Reviews grid -->
  <section style="background:#f2f4f9;padding:72px 0;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;" class="review-grid">
        {reviews.map(r => (
          <div style={`
            border-radius: 24px;
            padding: 28px;
            display: flex;
            flex-direction: column;
            ${r.dark
              ? 'background:#1c1e21;'
              : 'background:white;border:1px solid #e8edf0;'}
          `}>
            <!-- Stars -->
            <div style="display:flex;gap:3px;margin-bottom:16px;">
              {Array.from({length:r.rating}).map(() => (
                <iconify-icon icon="mdi:star" width="16" style="color:#f59e0b;"></iconify-icon>
              ))}
            </div>

            <!-- Quote mark -->
            <div style={`font-size:3rem;font-weight:900;line-height:0.8;margin-bottom:12px;${r.dark?'color:rgba(22,184,74,0.4);':'color:#dcfce7;'}`}>"</div>

            <p style={`font-size:0.9375rem;line-height:1.7;flex:1;margin-bottom:20px;${r.dark?'color:rgba(255,255,255,0.8);':'color:#4f606e;'}`}>{r.body}</p>

            <div style="border-top:1px solid rgba(255,255,255,0.07);padding-top:16px;display:flex;align-items:center;justify-content:space-between;" class:list={[!r.dark && 'light-divider']}>
              <div>
                <p style={`font-size:0.9375rem;font-weight:700;margin:0;${r.dark?'color:white;':'color:#0c0c0c;'}`}>{r.name}</p>
                <p style={`font-size:0.8125rem;margin:2px 0 0;${r.dark?'color:rgba(255,255,255,0.4);':'color:#8792a2;'}`}>{r.location} · {r.date}</p>
              </div>
              <span style={`font-size:0.75rem;font-weight:700;padding:4px 12px;border-radius:32px;white-space:nowrap;${r.dark?'background:rgba(22,184,74,0.15);color:#4ade80;':'background:#dcfce7;color:#15803d;'}`}>
                {r.service}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Leave a review -->
  <section style="background:#fff;padding:72px 0;border-top:1px solid #e8edf0;">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <div style="width:64px;height:64px;border-radius:64px;background:#dcfce7;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
        <iconify-icon icon="mdi:star-plus" width="32" style="color:#16b84a;"></iconify-icon>
      </div>
      <h2 style="font-size:2rem;font-weight:800;letter-spacing:-0.5px;color:#0c0c0c;margin-bottom:12px;">Worked with us? Leave a review</h2>
      <p style="color:#4f606e;font-size:1.0625rem;line-height:1.75;margin-bottom:28px;">
        Your feedback helps other La Jolla homeowners find a contractor they can trust.
      </p>
      <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:12px;">
        <a
          href="https://g.page/r/review"
          target="_blank"
          rel="noopener noreferrer"
          style="
            display:inline-flex;align-items:center;gap:10px;
            padding:12px 24px;border-radius:32px;
            border:2px solid #e8edf0;background:white;
            color:#0c0c0c;font-weight:700;font-size:0.9375rem;
            text-decoration:none;transition:border-color 0.15s;
          "
        >
          <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Review on Google
        </a>
        <a href="/contact" style="
          display:inline-flex;align-items:center;gap:8px;
          background-color:#0d8c32;color:white;
          font-weight:700;font-size:0.9375rem;text-transform:uppercase;
          padding:12px 24px;border-radius:32px;text-decoration:none;
        ">
          Get a free estimate
          <iconify-icon icon="mdi:arrow-right" width="18"></iconify-icon>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .light-divider { border-top-color: #e8edf0 !important; }
  @media (max-width: 1024px) { .review-grid { grid-template-columns: 1fr 1fr !important; } }
  @media (max-width: 768px) {
    .page-header { padding: 88px 0 40px !important; }
    .stats-val   { font-size: 1.75rem !important; }
    .stats-grid  { gap: 16px !important; }
  }
  @media (max-width: 640px)  { .review-grid, .stats-grid { grid-template-columns: 1fr !important; } }
  @media (max-width: 480px)  { .page-header { padding: 80px 0 32px !important; } }
</style>
